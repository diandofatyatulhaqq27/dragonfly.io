# ============================================================
# IIOT BACKEND - ENVIRONMENT VARIABLES
# Rename file ini jadi .env lalu sesuaikan nilainya
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# DB_HOST=db → pakai ini kalau run via `docker compose up`
# DB_HOST=localhost → pakai ini kalau run `uvicorn` langsung di lokal
# (pastikan container db & mqtt_broker tetap jalan: docker compose up -d db mqtt_broker)
DB_HOST=db
DB_PORT=5432
DB_USER=iiot_user
DB_PASSWORD=SuperSecret123!
DB_NAME=iiot_db

# ── MQTT ─────────────────────────────────────────────────────
# MQTT_HOST=mqtt_broker → docker compose
# MQTT_HOST=localhost → lokal langsung
MQTT_HOST=mqtt_broker
MQTT_PORT=1883
MQTT_USERNAME=iiot_mqtt
MQTT_PASSWORD=MqttSecret456!

# ── SECURITY ─────────────────────────────────────────────────
# Generate random: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti_dengan_output_perintah_diatas

# ── EMAIL ────────────────────────────────────────────────────
MAIL_USERNAME=email@domain.com
MAIL_PASSWORD=password_email_atau_app_password
MAIL_FROM=email@domain.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# ── URL ─────────────────────────────────────────────────────
FRONTEND_URL=https://dragonfly-io.vercel.app